{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",

		"strict": true,
		"noImplicitAny": false,
		"strictNullChecks": true,

		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		// "noUncheckedSideEffectImports": false,

		"noEmit": true,
		"isolatedModules": true,

		"allowJs": false,
		"checkJs": false,

		"skipLibCheck": true,

		"paths": {
			"@ui/*": ["./src/ui/*"],
			"@/*": ["./src/*"]
		},
		"allowArbitraryExtensions": true,

		"types": ["vite/client"]
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "eslint.config.ts"]
}